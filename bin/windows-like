#!/usr/bin/env bash
# windows-like — abre el entorno Windows-like en una ventana de tamano fijo
# 1366x768 (modo ventana). Resolucion fija por simplicidad y estabilidad: la
# deteccion automatica del area de trabajo resulto fragil entre monitores y
# bajo XWayland, asi que se usa un tamano 16:9 conservador que cabe en
# cualquier pantalla moderna sin tapar los paneles de KDE.
set -euo pipefail
export WINEPREFIX="${WINEPREFIX:-$HOME/.wine}"
export WINEDEBUG="${WINEDEBUG:--all}"
WINE_BIN="$(command -v wine || echo /usr/bin/wine)"
RES="1366x768"

# Canvas interno del escritorio "shell" = tamano de la ventana.
"$WINE_BIN" reg add "HKCU\\Software\\Wine\\Explorer\\Desktops" \
  /v shell /t REG_SZ /d "$RES" /f >/dev/null 2>&1 || true

# Si ya hay una sesion abierta, traerla al frente en vez de duplicar.
EXISTING="$(xdotool search --name "Wine Desktop" 2>/dev/null | head -1 || true)"
if [ -n "$EXISTING" ]; then
  xdotool windowactivate "$EXISTING" 2>/dev/null || true
  exit 0
fi

exec "$WINE_BIN" explorer "/desktop=shell,$RES"
