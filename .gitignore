# Indice generado por memsearch al indexar el repo
.memsearch/

# Cache de bytecode Python
__pycache__/
*.pyc

# Respaldos y temporales
*.bak
*.bak-*
*.tmp
*.log
*~

# Descargas/cache de instaladores (se obtienen por script)
*.msi
*.exe

# Source congelado (vendoring): pesado, fuera del repo. El manifiesto
# vendor/sources.lock + fetch-sources.sh SI se versionan (reconstruyen el cache).
vendor/cache/
